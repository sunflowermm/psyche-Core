  "questions": [
    {
      "id": "sc1",
      "dim": "S1",
      "text": "刷到别人高光生活九宫格，你的内心 OS：",
      "options": [
        {
          "label": "我不配，关掉保平安",
          "value": 1
        },
        {
          "label": "羡慕三秒，该干嘛干嘛",
          "value": 2
        },
        {
          "label": "看看就好，我有自己的节奏",
          "value": 3
        }
      ]
    },
    {
      "id": "sc2",
      "dim": "S1",
      "text": "突然被公开表扬，你更像：",
      "options": [
        {
          "label": "「是不是搞错了」并开始找地缝",
          "value": 1
        },
        {
          "label": "开心一下，很快恢复平常",
          "value": 2
        },
        {
          "label": "坦然收下：嗯，确实是我",
          "value": 3
        }
      ]
    },
    {
      "id": "sc3",
      "dim": "S2",
      "text": "独处一整晚后，「我是谁」这条频道：",
      "options": [
        {
          "label": "雪花屏，像掉线",
          "value": 1
        },
        {
          "label": "时清时糊，看当天状态",
          "value": 2
        },
        {
          "label": "反而更清楚自己要什么",
          "value": 3
        }
      ]
    },
    {
      "id": "sc4",
      "dim": "S2",
      "text": "换城市/换身份（升学、入职）后：",
      "options": [
        {
          "label": "要很久才能拼出新版自己",
          "value": 1
        },
        {
          "label": "慢慢适应，中间会摇摆",
          "value": 2
        },
        {
          "label": "较快整合出「新皮肤」",
          "value": 3
        }
      ]
    },
    {
      "id": "sc5",
      "dim": "S3",
      "text": "未来十年只能选一种生活主题：",
      "options": [
        {
          "label": "安稳舒适，少折腾",
          "value": 1
        },
        {
          "label": "既要稳定也要一点成长",
          "value": 2
        },
        {
          "label": "成长/创造/信念驱动，冲",
          "value": 3
        }
      ]
    },
    {
      "id": "sc6",
      "dim": "E1",
      "text": "重要的人几小时没回消息，你：",
      "options": [
        {
          "label": "脑内小剧场已演到分手",
          "value": 1
        },
        {
          "label": "有点在意但还能等",
          "value": 2
        },
        {
          "label": "默认在忙，不急着解读",
          "value": 3
        }
      ]
    },
    {
      "id": "sc7",
      "dim": "E2",
      "text": "进入新关系（友情/爱情），你的投入速度：",
      "options": [
        {
          "label": "慢热，观察很久才敞开",
          "value": 1
        },
        {
          "label": "看感觉，有时快有时慢",
          "value": 2
        },
        {
          "label": "认定后容易全情梭哈",
          "value": 3
        }
      ]
    },
    {
      "id": "sc8",
      "dim": "E2",
      "text": "对方情绪低落，你更常：",
      "options": [
        {
          "label": "不知道说啥，先躲一躲",
          "value": 1
        },
        {
          "label": "陪一会儿，但留安全距离",
          "value": 2
        },
        {
          "label": "愿意花时间接住 TA",
          "value": 3
        }
      ]
    },
    {
      "id": "sc9",
      "dim": "E3",
      "text": "亲密关系里，「个人空间」对你：",
      "options": [
        {
          "label": "不太需要，黏一起更安心",
          "value": 1
        },
        {
          "label": "要一点，但也能共享很多",
          "value": 2
        },
        {
          "label": "必须有，再爱也要留白",
          "value": 3
        }
      ]
    },
    {
      "id": "sc10",
      "dim": "A1",
      "text": "陌生人向你求助，第一反应：",
      "options": [
        {
          "label": "先想会不会是套路",
          "value": 1
        },
        {
          "label": "看场合和直觉",
          "value": 2
        },
        {
          "label": "更愿意相信对方是善意的",
          "value": 3
        }
      ]
    },
    {
      "id": "sc11",
      "dim": "A2",
      "text": "团队规则很蠢但无害，你会：",
      "options": [
        {
          "label": "能绕就绕，舒服第一",
          "value": 1
        },
        {
          "label": "大部分遵守，个别变通",
          "value": 2
        },
        {
          "label": "尽量按规矩，减少变量",
          "value": 3
        }
      ]
    },
    {
      "id": "sc12",
      "dim": "A3",
      "text": "最近几周像「在重复播放同一集」：",
      "options": [
        {
          "label": "挺常见，活着而已",
          "value": 1
        },
        {
          "label": "偶尔空虚，找点小事填",
          "value": 2
        },
        {
          "label": "会主动找方向感或意义",
          "value": 3
        }
      ]
    },
    {
      "id": "sc13",
      "dim": "Ac1",
      "text": "有个可能有坑但很有趣的机会：",
      "options": [
        {
          "label": "算了，稳字当头",
          "value": 1
        },
        {
          "label": "掂量利弊再决定",
          "value": 2
        },
        {
          "label": "冲，成长比安全重要",
          "value": 3
        }
      ]
    },
    {
      "id": "sc14",
      "dim": "Ac2",
      "text": "网购二选一纠结半小时——",
      "options": [
        {
          "label": "太正常了，我日常",
          "value": 1
        },
        {
          "label": "偶尔，大事才这样",
          "value": 2
        },
        {
          "label": "很少，差不多就下单",
          "value": 3
        }
      ]
    },
    {
      "id": "sc15",
      "dim": "Ac3",
      "text": "todo 堆了十件事，你：",
      "options": [
        {
          "label": "等 deadline 帮我排序",
          "value": 1
        },
        {
          "label": "挑简单的先做",
          "value": 2
        },
        {
          "label": "按优先级逐个清",
          "value": 3
        }
      ]
    },
    {
      "id": "sc16",
      "dim": "Ac3",
      "text": "答应别人的事，兑现率更接近：",
      "options": [
        {
          "label": "看心情和记性",
          "value": 1
        },
        {
          "label": "重要的会做到",
          "value": 2
        },
        {
          "label": "说了就做，尽量不鸽",
          "value": 3
        }
      ]
    },
    {
      "id": "sc17",
      "dim": "So1",
      "text": "线下聚会大多是陌生人，你：",
      "options": [
        {
          "label": "角落玩手机保平安",
          "value": 1
        },
        {
          "label": "跟一两个人深聊",
          "value": 2
        },
        {
          "label": "主动认识几个",
          "value": 3
        }
      ]
    },
    {
      "id": "sc18",
      "dim": "So2",
      "text": "朋友突然开过分玩笑，你：",
      "options": [
        {
          "label": "笑笑带过，心里记一笔",
          "value": 1
        },
        {
          "label": "当场或事后温和说明",
          "value": 2
        },
        {
          "label": "直接划边界，不惯着",
          "value": 3
        }
      ]
    },
    {
      "id": "sc19",
      "dim": "So3",
      "text": "在社交媒体发内容，你更在意：",
      "options": [
        {
          "label": "人设别崩，说安全的",
          "value": 1
        },
        {
          "label": "看心情，有时真有时演",
          "value": 2
        },
        {
          "label": "尽量真实，哪怕不完美",
          "value": 3
        }
      ]
    },
    {
      "id": "sc20",
      "dim": "So3",
      "text": "和熟人意见相反，气氛已经有点僵：",
      "options": [
        {
          "label": "闭嘴，避免冲突",
          "value": 1
        },
        {
          "label": "软一点表达，不硬刚",
          "value": 2
        },
        {
          "label": "仍会把真实想法说清楚",
          "value": 3
        }
      ]
    },
    {
      "id": "sc21",
      "dim": "N1",
      "text": "明天有重要展示，今晚你：",
      "options": [
        {
          "label": "反复预演各种翻车场景",
          "value": 1
        },
        {
          "label": "有点紧张但能睡",
          "value": 2
        },
        {
          "label": "准备够了就放松",
          "value": 3
        }
      ]
    },
    {
      "id": "sc22",
      "dim": "N2",
      "text": "突然获得一整天空闲，没有安排：",
      "options": [
        {
          "label": "反而焦虑，不知道干嘛",
          "value": 1
        },
        {
          "label": "休息刷剧，挺满足",
          "value": 2
        },
        {
          "label": "兴奋，想试新东西",
          "value": 3
        }
      ]
    }
  ],
