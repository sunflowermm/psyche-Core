        },
        {
          "value": "tea",
          "label": "茶 / 功能饮料"
        },
        {
          "value": "coffee",
          "label": "咖啡续命"
        },
        {
          "value": "cola",
          "label": "奶茶 / 可乐"
        }
      ]
    },
    {
      "id": 32,
      "hiddenKey": "drinkAttitude",
      "triggerKey": "drink",
      "triggerPrev": "coffee",
