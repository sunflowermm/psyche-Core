      "options": [
        {
          "value": "casual",
          "label": "一杯，够用了"
        },
        {
          "value": "addict",
          "label": "三杯起步，否则 merge 不了"
        }
      ]
    },
    {
      "id": 33,
      "hiddenKey": "nightOwl",
      "text": "彩蛋 · 你最高产的时段：",
      "options": [
        {
          "value": "early",
          "label": "上午，头脑最清醒"
        },
        {
          "value": "normal",
          "label": "下午，看当天状态"
        },
        {
          "value": "owl",
          "label": "深夜，世界终于安静了"
        }
      ]
    }
  ]
}
